PORT=3000

# OpenAI (required unless DRY_RUN=1)
OPENAI_API_KEY=

# Twilio (required unless DRY_RUN=1)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Public Calendly scheduling link (overrides business.json if set)
CALENDLY_URL=https://calendly.com/your-link/consult

# Optional: require Authorization: Bearer <secret> on POST /webhook/formspree
WEBHOOK_SECRET=

# Set to 1 to log AI output without sending SMS (safe local testing)
DRY_RUN=0
